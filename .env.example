# Copy to .env and fill in (bun loads .env automatically).
# This project talks to Ollama Cloud via its OpenAI-compatible API.

# Port the HTTP server listens on (default: 3000)
PORT=3000

# Ollama Cloud API key — create one at https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Ollama-native base URL (used by src/utils/raw_agent.ts via the `ollama` SDK).
# Ollama Cloud: https://ollama.com
# Local Ollama fallback (no key needed): http://localhost:11434
OLLAMA_API_URL=https://ollama.com

# Model name. Must be a model available on Ollama Cloud, e.g.:
#   glm-5.2, gpt-oss:120b, deepseek-v4-pro, qwen3-coder:480b
# (list them: curl https://ollama.com/v1/models)
# Note: the code's fallback (gpt-4o-mini) does not exist on Ollama, so set this.
MODEL=glm-5.2:cloud

# --- Phoenix tracing ---
# Set to "false" to disable tracing entirely (spans become no-ops).
PHOENIX_TRACING_ENABLED=true
# Local Phoenix from docker-compose.yml (UI + OTLP HTTP on the same port).
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_PROJECT_NAME=solenoid-assistant
